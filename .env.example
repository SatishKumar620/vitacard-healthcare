# Server Configuration
PORT=7860

# Sarvam AI Key (Translation, Speech-to-Text, Text-to-Speech)
SARVAM_API_KEY=your_sarvam_api_key_here

# Resend API Key (Email notifications for appointment booking)
RESEND_API_KEY=your_resend_api_key_here

# n8n Basic Authentication (optional)
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=vitacard

# Cohere API Key (PostgreSQL Vector embeddings generator)
COHERE_API_KEY=your_cohere_api_key_here

# Groq API Key (LLM model for question generation & ranking)
GROQ_API_KEY=your_groq_api_key_here
